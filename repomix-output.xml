18:         self,
19:         stream: TextIO = default_output,
20:         min_level: Level = Level.NOTSET,
21:         formatter: Formatter | None = None,
22:         filters: list[Filter] | None = None,
23:     ) -> None:
24:         super().__init__(min_level, formatter, filters)
25:         if not callable(getattr(stream, "write", None)):
26:             msg = "stream must provide a callable 'write' method"
