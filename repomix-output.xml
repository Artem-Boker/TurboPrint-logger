 1: from __future__ import annotations
 2: 
 3: from re import IGNORECASE
 4: from re import compile as re_compile
 5: from typing import Literal, get_args
 6: 
 7: from turboprint_logger.core.record import Record
 8: from turboprint_logger.exceptions.filters.name import InvalidFilterModeError
 9: from turboprint_logger.interfaces import Filter
10: 
11: __all__ = ("NameFilter",)
12: 
13: _MODES = Literal["exact", "startswith", "endswith", "contains", "regex"]
14: 
15: 
16: class NameFilter(Filter):
17:     def __init__(self, pattern: str, mode: _MODES, *, ignorecase: bool = True) -> None:
18:         if mode.lower() not in get_args(_MODES):
19:             msg = f"Invalid mode: {mode.lower()}"
20:             raise InvalidFilterModeError(msg)
21: 
22:         self.pattern = pattern
23:         self.mode = mode.lower()
24:         self.ignorecase = ignorecase
25: 
26:         flags = IGNORECASE if ignorecase else 0
27:         self._regex = re_compile(pattern, flags)
28: 
29:     def filter(self, record: Record) -> bool:
30:         name = record.logger.name
31:         pattern = self.pattern
32:         if self.ignorecase:
33:             name = name.lower()
34:             pattern = pattern.lower()
35: 
36:         match self.mode:
37:             case "exact":
38:                 return name == pattern
39:             case "startswith":
40:                 return name.startswith(pattern)
41:             case "endswith":
42:                 return name.endswith(pattern)
43:             case "contains":
44:                 return pattern in name
45:             case "regex":
46:                 return bool(self._regex.search(name))
47:             case _:
48:                 return False
</file>

