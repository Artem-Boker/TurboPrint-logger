137:         if not isinstance(loggers, dict):
138:             msg = "Config key 'loggers' must be a dict"
139:             raise ConfigSpecError(msg)
140:         for name, raw_spec in loggers.items():
141:             if not isinstance(name, str):
142:                 msg = f"Logger name must be a string, got: {type(name).__name__}"
143:                 raise ConfigSpecError(msg)
144:             if not isinstance(raw_spec, dict):
145:                 msg = f"Logger config for '{name}' must be a dict"
146:                 raise ConfigSpecError(msg)
147:             logger_name = _ROOT_LOGGER_NAME if name == _ROOT_LOGGER_NAME else name
148: 
149:             logger = Logger.get_logger(logger_name, container=self._container)
150:             self._apply_logger(logger, raw_spec, merge=merge)
