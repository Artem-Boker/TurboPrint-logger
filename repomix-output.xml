<file path="src/turboprint_logger/filters/context.py">
 1: from __future__ import annotations
 2: 
 3: from collections.abc import Callable
 4: from re import Pattern
 5: 
 6: from turboprint_logger.core.record import Record
 7: from turboprint_logger.interfaces import Filter
 8: 
 9: __all__ = ("ContextFilter",)
10: 
11: 
12: class ContextFilter(Filter):
13:     def __init__(
14:         self,
15:         *,
16:         match_all: bool = True,
17:         **conditions: object | Callable[[object], bool] | Pattern[str],
18:     ) -> None:
19:         self.conditions = conditions
20:         self.check = all if match_all else any
21: 
22:     @staticmethod
23:     def _check_condition(condition: object, actual: object) -> bool:
24:         if callable(condition):
25:             try:
26:                 return condition(actual)  # type: ignore[no-any-return]
27:             except Exception:  # noqa: BLE001
28:                 return False
29:         elif isinstance(condition, Pattern):
30:             return bool(condition.search(str(actual)))  # type: ignore[no-matching-overload]
31:         else:
32:             return actual == condition
33: 
34:     def filter(self, record: Record) -> bool:
35:         context = record.context
36: 
37:         return self.check(
38:             self._check_condition(condition, context.get(key))
39:             for key, condition in self.conditions.items()
40:         )
</file>

