 30:         self,
 31:         *,
 32:         include: list[str] | None = None,
 33:         exclude: list[str] | None = None,
 34:         rename: dict[str, str] | None = None,
 35:         sort_keys: bool = False,
 36:         **extra,
 37:     ) -> None:
 38:         self.include = set(include) if include else None
 39:         self.exclude = set(exclude) if exclude else None
 40:         self.rename = rename or {}
 41:         self.extra = extra or {}
 42:         self.sort_keys = sort_keys
 43: 
 44:         if JSON_MODULE == "msgspec":
 45:             order = "sorted" if sort_keys else "deterministic"
 46:             self._encoder = Encoder(enc_hook=self._default_serializer, order=order)
 47:         elif JSON_MODULE == "orjson":
 48:             self._orjson_option = orjson.OPT_SERIALIZE_NUMPY
 49:             if sort_keys:
 50:                 self._orjson_option |= orjson.OPT_SORT_KEYS
 51: 
 52:     @staticmethod
 53:     def _default_serializer(obj: Any) -> Any:  # noqa: ANN401
 54:         if isinstance(obj, dict):
 55:             return obj
 56:         if isinstance(obj, (datetime, date, time)):
 57:             return obj.isoformat()
 58:         for method_name in ("dict", "to_dict", "__json__", "__dict__"):
 59:             method_obj = getattr(obj, method_name, None)
 60:             if callable(method_obj):
 61:                 return method_obj()
 62:         return str(obj)
 63: 
 64:     def format(self, record: Record) -> str:
 65:         message = record.message() if callable(record.message) else record.message  # ty:ignore[call-top-callable]
 66: 
 67:         data: dict[str, Any] = {
 68:             "message": message,
 69:             "level": {
 70:                 "name": record.level.name,
 71:                 "value": record.level.level,
 72:             },
 73:             "logger": record.logger.name,
 74:             "timestamp": record.date_time.isoformat(),
 75:             "caller": {
 76:                 "file": record.file,
 77:                 "function": record.function,
 78:                 "line": record.line,
 79:             },
 80:             "context": self._default_serializer({**record.context, **self.extra}),
 81:         }
 82: 
 83:         for old, new in self.rename.items():
 84:             if old in data:
 85:                 data[new] = data.pop(old)
 86: 
 87:         if self.exclude:
 88:             data = {
 89:                 key: value for key, value in data.items() if key not in self.exclude
 90:             }
 91: 
 92:         if self.include:
 93:             data = {key: value for key, value in data.items() if key in self.include}
 94: 
 95:         if JSON_MODULE == "orjson":
 96:             return orjson.dumps(
 97:                 data, default=self._default_serializer, option=self._orjson_option
 98:             ).decode("utf-8")
 99:         if JSON_MODULE == "msgspec":
100:             return self._encoder.encode(data).decode("utf-8")
101:         return dumps(
102:             data,
103:             ensure_ascii=False,
104:             default=self._default_serializer,
105:             sort_keys=self.sort_keys,
106:         )
