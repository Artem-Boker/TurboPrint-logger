39: class SimpleFormatter(Formatter):
40:     def __init__(
41:         self,
42:         template: str = "[${date} ${time}] ${logger_name} | ${level_name}: ${message}",
43:         date_format: str | None = None,
44:         time_format: str | None = None,
45:         *,
46:         colored: bool = False,
47:     ) -> None:
48:         self.template = Template(template)
49:         self.date_format = date_format
50:         self.time_format = time_format
51:         self.colored = colored
52: 
53:     def format(self, record: Record) -> str:
54:         message = record.message() if callable(record.message) else record.message  # ty:ignore[call-top-callable]
55:         message = Template(message).safe_substitute(record.context)
56: 
57:         date_obj = record.date_time.date()
58:         date_str = (
59:             date_obj.strftime(self.date_format)
60:             if self.date_format
61:             else date_obj.isoformat()
62:         )
63: 
64:         time_obj = record.date_time.time()
65:         time_str = (
66:             time_obj.strftime(self.time_format)
67:             if self.time_format
68:             else time_obj.isoformat()
69:         )
70: 
71:         record_format = FormatDict(
72:             message=message,
73:             level=record.level,
74:             level_name=record.level.name,
75:             level_value=record.level.level,
76:             level_emoji=record.level.emoji,
77:             logger=record.logger,
78:             logger_name=record.logger.name,
79:             date=date_str,
80:             time=time_str,
81:             datetime=record.date_time,
82:             trace_id=record.trace_id,
