 1: from __future__ import annotations
 2: 
 3: from collections import Counter
 4: from threading import Lock
 5: 
 6: from turboprint_logger.core.levels import Level, Level
 7: from turboprint_logger.exceptions.managers.metrics import NegativeMetricsCountError
 8: 
 9: __all__ = ("MetricsManager",)
10: 
11: 
12: class MetricsManager:
13:     __slots__ = ("_lock", "_metrics")
14: 
15:     def __init__(self) -> None:
16:         self._lock = Lock()
17:         self._metrics: Counter[int] = Counter()
18: 
19:     def get(self) -> dict[int, int]:
20:         with self._lock:
21:             return self._metrics.copy()
22: 
23:     def add(self, level: Level) -> None:
24:         with self._lock:
25:             self._metrics[level.level] += 1
26: 
27:     def subtract(self, level: Level) -> bool:
28:         with self._lock:
29:             key = level.level
30:             if key not in self._metrics:
31:                 return False
32:             if self._metrics.get(key, 0) <= 1:
33:                 del self._metrics[key]
34:                 return True
35:             self._metrics[key] -= 1
36:             return True
37: 
38:     def total(self) -> int:
39:         with self._lock:
40:             return self._metrics.total()
41: 
42:     def items(self) -> dict[Level, int]:
43:         with self._lock:
44:             result = {}
45:             for level_int, count in self._metrics.items():
46:                 level = Level.get_by_level(level_int)
47:                 if level:
48:                     result[level] = count
49:             return result
50: 
51:     def reset(self, level: Level | None = None) -> None:
52:         with self._lock:
53:             if level is not None:
54:                 self._metrics.pop(level.level, 0)
55:             else:
56:                 self._metrics.clear()
57: 
58:     def __getitem__(self, level: Level) -> int:
59:         with self._lock:
60:             return self._metrics.get(level.level, 0)
61: 
62:     def __delitem__(self, level: Level) -> None:
63:         with self._lock:
64:             del self._metrics[level.level]
65: 
66:     def __setitem__(self, level: Level, count: int) -> None:
67:         if count < 0:
68:             msg = f"Metrics count cannot be negative, got {count}"
69:             raise NegativeMetricsCountError(msg)
70:         with self._lock:
71:             self._metrics[level.level] = count
72: 
73:     def __str__(self) -> str:
74:         return f"{self.__class__.__name__}(total_metrics={self.total()})"
75: 
76:     def __repr__(self) -> str:
77:         return (
78:             f"{self.__class__.__name__}(metrics={self.items()}, total={self.total()})"
79:         )
</file>

