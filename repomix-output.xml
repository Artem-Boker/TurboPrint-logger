 8: from turboprint_logger.interfaces import Filter, Formatter
 9: 
10: __all__ = ("Handler",)
11: 
12: 
13: class Handler(ABC):
14:     __slots__ = ("filters", "formatter", "level")
15: 
16:     def __init__(
17:         self,
18:         min_level: Level = Level.NOTSET,
19:         formatter: Formatter | None = None,
20:         filters: list[Filter] | None = None,
21:     ) -> None:
22:         self.level = min_level
23:         self.formatter = formatter
24:         self.filters = filters or []
25: 
26:     def handle(self, record: Record) -> None:
27:         if record.level.level >= self.level.level and all(
28:             f.filter(record) for f in self.filters
29:         ):
30:             self.emit(record)
31: 
32:     @abstractmethod
33:     def emit(self, record: Record) -> None:
34:         msg = "Handler.emit must be implemented by subclasses"
35:         raise InterfaceMethodNotImplementedError(msg)
36: 
37:     def __str__(self) -> str:
38:         return self.__class__.__name__
39: 
40:     def __repr__(self) -> str:
41:         return (
42:             f"{self.__class__.__name__}("
43:             f"min_level={self.level}, "
44:             f"formatter={self.formatter}, "
45:             f"filters={tuple(self.filters)})"
46:         )
