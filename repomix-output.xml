 9: class TagFilter(Filter):
10:     def __init__(
11:         self, *required_tags: str, match_all: bool = True, opposite: bool = False
12:     ) -> None:
13:         self.required = required_tags
14:         self.check = all if match_all else any
15:         self.opposite = opposite
16: 
