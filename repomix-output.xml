 89:             msg = f"Config file does not exist or is not a file: {path}"
 90:             raise ConfigParserError(msg)
 91:         suffix = path.suffix.strip().lower().removeprefix(".")
 92:         with self._lock:
 93:             parser = self._parsers.get(suffix)
 94:         if not parser:
 95:             msg = f"Unsupported config extension: {path.suffix or '<none>'}"
 96:             raise ConfigParserError(msg)
 97:         try:
 98:             size = path.stat().st_size
 99:             if size > _MAX_CONFIG_BYTES:
100:                 msg = (
101:                     f"Config file {path} is too large: {size} bytes. "
102:                     f"Maximum allowed is {_MAX_CONFIG_BYTES} bytes"
103:                 )
104:                 raise ConfigParserError(msg)
105:             source = path.read_text(encoding="utf-8")
106:         except OSError as exc:
107:             msg = f"Unable to read config file {path}: {exc}"
108:             raise ConfigParserError(msg) from exc
109:         except UnicodeDecodeError as exc:
110:             msg = f"Config file {path} is not valid UTF-8: {exc}"
111:             raise ConfigParserError(msg) from exc
112:         try:
113:             data = parser(source)
114:         except ConfigParserError:
