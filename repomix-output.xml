236:                 except Exception as exc:  # noqa: BLE001
237:                     sys.stderr.write(
238:                         f"Exception in {handler.__class__.__name__}: {exc}\n"
239:                     )
240: 
241:         return True
242: 
243:     def _process_local(self, record: Record) -> bool:
244:         if not self.status.logger.enabled:
245:             return False
246: 
247:         if not record.level.enabled_for(self.level.get()):
248:             return False
249: 
250:         for processor in self.processors:
251:             try:
252:                 processed_record = processor.process(record)
253:                 if processed_record:
254:                     record = processed_record
255:             except Exception as exc:  # noqa: BLE001
256:                 sys.stderr.write(
257:                     f"Exception in {processor.__class__.__name__}: {exc}\n"
258:                 )
259: 
260:         if self.status.filters.enabled and not all(
261:             f.filter(record) for f in self.filters
262:         ):
263:             return False
264: 
265:         if self.status.handlers.enabled:
266:             for handler in self.handlers:
267:                 try:
268:                     handler.handle(record)
269:                 except Exception as exc:  # noqa: BLE001
270:                     sys.stderr.write(
271:                         f"Exception in {handler.__class__.__name__}: {exc}\n"
272:                     )
273: 
274:         return True
275: 
276:     def _process_record(self, record: Record) -> None:
277:         current = self
278:         while current:
279:             if not current._process_local(record):
280:                 return
281:             if not current.propagate or current is current.parent:
282:                 break
283:             current = current.parent
284:         self.metrics.add(record.level)
285: 
286:     def __call__(
287:         self,
288:         level: Level | str,
289:         message: str | Callable[[], str],
290:         *,
291:         tags: list[str] | None = None,
292:         **extra,
293:     ) -> Record:
294:         merged_tags = self._merge_tags(tags)
295:         merged_context = self._merge_context(extra)
296:         record = self._create_record(level, message, merged_tags, merged_context)
297:         self._process_global(record)
298:         self._process_record(record)
299:         return record
300: 
301:     def __str__(self) -> str:
302:         return f"{self.__class__.__name__}({self.name})"
303: 
304:     def __repr__(self) -> str:
305:         return (
306:             f"{self.__class__.__name__}("
307:             f'name="{self.name}", '
308:             f"logger_id={self._logger_id}, "
309:             f'container_name="{self._container.name}", '
310:             f"propagate={self.propagate}, "
311:             f"min_level={self.level.get()!r}, "
312:             f"formatter={self.formatter.get()}, "
313:             f"filters={self.filters.get()}, "
314:             f"handlers={self.handlers.get()}, "
315:             f"context_keys={tuple(self.context.keys())}, "
316:             f"tags={tuple(self.tags.get())}, "
317:             f"status={self.status})"
318:         )
