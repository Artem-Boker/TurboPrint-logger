<file path="src/turboprint_logger/integrations/logging.py">
 1: from __future__ import annotations
 2: 
 3: import logging
 4: from typing import Any
 5: 
 6: from src.turboprint_logger.utils.reserved import filter_reserved
 7: from turboprint_logger.core.levels import Level, Level
 8: from turboprint_logger.core.logger import Logger
 9: 
10: __all__ = ("LoggingAdapter", "install_adapter")
11: 
12: _STD_TO_CUSTOM_LEVEL = {
13:     logging.NOTSET: Level.NOTSET,
14:     logging.DEBUG: Level.DEBUG,
15:     logging.INFO: Level.INFO,
16:     logging.WARN: Level.WARNING,
17:     logging.WARNING: Level.WARNING,
18:     logging.ERROR: Level.ERROR,
19:     logging.FATAL: Level.CRITICAL,
20:     logging.CRITICAL: Level.CRITICAL,
21: }
22: 
23: 
24: class LoggingAdapter(logging.Handler):
25:     def __init__(self, level: int = logging.NOTSET) -> None:
26:         super().__init__(level)
27: 
28:     def emit(self, record: logging.LogRecord) -> None:
29:         try:
30:             custom_logger = Logger.get_logger(record.name)
31:         except Exception:
32:             self.handleError(record)
33:             return
34:         level = self._convert_level(record.levelno)
35:         message = record.getMessage()
36:         extra = filter_reserved(self._extract_extra(record))
37:         custom_logger(level, message, **extra)
38: 
39:     def _convert_level(self, levelno: int) -> Level:
40:         if levelno in _STD_TO_CUSTOM_LEVEL:
41:             return _STD_TO_CUSTOM_LEVEL[levelno]
42: 
43:         custom_level = Level.get_by_level(levelno)
44:         if custom_level is not None:
45:             return custom_level
46: 
47:         return Level.NOTSET
48: 
49:     def _extract_extra(self, record: logging.LogRecord) -> dict[str, Any]:
50:         std_attrs = {
51:             "args",
52:             "asctime",
53:             "created",
54:             "exc_info",
55:             "exc_text",
56:             "filename",
57:             "funcName",
58:             "levelname",
59:             "levelno",
60:             "lineno",
61:             "module",
62:             "msecs",
63:             "message",
64:             "msg",
65:             "name",
66:             "pathname",
67:             "process",
68:             "processName",
69:             "relativeCreated",
70:             "stack_info",
71:             "taskName",
72:             "thread",
73:             "threadName",
74:         }
75:         return {
76:             key: value
77:             for key, value in record.__dict__.items()
78:             if key not in std_attrs and not key.startswith("_")
79:         }
80: 
81: 
82: def install_adapter(level: int = logging.NOTSET) -> LoggingAdapter:
83:     handler = LoggingAdapter(level)
84:     logging.root.addHandler(handler)
85:     return handler
</file>

