 1: from __future__ import annotations
 2: 
 3: from re import IGNORECASE
 4: from re import compile as re_compile
 5: from typing import Any
 6: 
 7: from turboprint_logger.core.record import Record
 8: from turboprint_logger.interfaces import Formatter
 9: 
10: __all__ = ("SecurityFormatter",)
11: 
12: 
13: class SecurityFormatter(Formatter):
14:     def __init__(
15:         self,
16:         inner: Formatter,
17:         *,
18:         sensitive_fields: list[str] | None = None,
19:         sensitive_patterns: list[str] | None = None,
20:         mask_char: str = "*",
21:     ) -> None:
22:         self.inner = inner
23:         self.sensitive_fields = sensitive_fields or [
24:             "password",
25:             "token",
26:             "secret",
27:             "api_key",
28:             "auth",
29:             "credit_card",
30:         ]
31:         self.sensitive_patterns = sensitive_patterns or []
32:         self._compiled_patterns = [
33:             re_compile(pattern, IGNORECASE) for pattern in self.sensitive_patterns
34:         ]
35:         self.mask_char = mask_char
36: 
37:     def _mask_process(self, item: Any) -> Any:  # noqa: ANN401
38:         if isinstance(item, list | tuple | set):
39:             return [self._mask_process(i) for i in item]
40:         if isinstance(item, dict):
41:             masked: dict[str, Any] = {}
42:             for key, value in item.items():
43:                 if not isinstance(key, str):
44:                     masked[key] = value
45:                 elif key in self.sensitive_fields:
46:                     masked[key] = "***"
47:                 else:
48:                     masked[key] = self._mask_process(value)
49:             return masked
50:         if isinstance(item, str) and any(
51:             pattern.search(item) for pattern in self._compiled_patterns
52:         ):
53:             return self.mask_char * len(item)
54:         return item
55: 
56:     def format(self, record: Record) -> str:
57:         masked_context = self._mask_process(record.context)
58: 
59:         message = record.message() if callable(record.message) else record.message  # ty:ignore[call-top-callable]
60:         masked_message = self._mask_process(message)
61: 
62:         new_record = record.copy()
63:         new_record.context = masked_context
64:         new_record.message = masked_message
65: 
66:         return self.inner.format(new_record)
</file>

