 1: from __future__ import annotations
 2: 
 3: import re
 4: 
 5: from turboprint_logger.exceptions.utils.normalizers import (
 6:     InvalidContainerNameError,
 7:     InvalidContextKeyError,
 8:     InvalidLevelNameError,
 9:     InvalidLoggerNameError,
10: )
11: 
12: __all__ = (
13:     "normalize_container_name",
14:     "normalize_context_key",
15:     "normalize_level_name",
16:     "normalize_logger_name",
17: )
18: 
19: _PATTERN_CONTAINER = re.compile(r"[a-z0-9_-]+", re.IGNORECASE)
20: _PATTERN_LOGGER = re.compile(r"[a-z0-9_.-]+", re.IGNORECASE)
21: _PATTERN_LEVEL = re.compile(r"[a-z_-]+", re.IGNORECASE)
22: _PATTERN_CONTEXT = re.compile(r"[a-z0-9_-]+", re.IGNORECASE)
23: 
24: _BAD_BOUNDARIES = re.compile(r"^[_.-]|[_.-]$", re.IGNORECASE)
25: _BAD_DOUBLE = re.compile(r"[_.-]{2,}", re.IGNORECASE)
26: 
27: 
28: def _normalize(name: str, pattern: re.Pattern, *, upper: bool = True) -> str | None:
29:     name = name.strip().upper() if upper else name.strip().lower()
30:     if not pattern.fullmatch(name):
31:         return None
32:     if _BAD_BOUNDARIES.search(name):
33:         return None
34:     if _BAD_DOUBLE.search(name):
35:         return None
36:     return name
37: 
38: 
39: def normalize_container_name(name: str) -> str:
40:     normal_name = _normalize(name, _PATTERN_CONTAINER, upper=False)
41:     if not normal_name:
42:         msg = f"Invalid container name: {name}"
43:         raise InvalidContainerNameError(msg)
44:     return normal_name
45: 
46: 
47: def normalize_logger_name(name: str) -> str:
48:     normal_name = _normalize(name, _PATTERN_LOGGER, upper=False)
49:     if not normal_name:
50:         msg = f"Invalid logger name: {name}"
51:         raise InvalidLoggerNameError(msg)
52:     return normal_name
53: 
54: 
55: def normalize_level_name(name: str) -> str:
56:     normal_name = _normalize(name, _PATTERN_LEVEL, upper=True)
57:     if not normal_name:
58:         msg = f"Invalid level name: {name}"
59:         raise InvalidLevelNameError(msg)
60:     return normal_name
61: 
62: 
63: def normalize_context_key(key: str) -> str:
64:     normal_name = _normalize(key, _PATTERN_CONTEXT, upper=False)
65:     if not normal_name:
66:         msg = f"Invalid context key: {key}"
67:         raise InvalidContextKeyError(msg)
68:     return normal_name
