<file path="src/turboprint_logger/processors/lazy_message.py">
 1: from __future__ import annotations
 2: 
 3: from turboprint_logger.core.record import Record
 4: from turboprint_logger.interfaces import Processor
 5: 
 6: __all__ = ("LazyMessageProcessor",)
 7: 
 8: 
 9: class LazyMessageProcessor(Processor):
10:     def process(self, record: Record) -> Record:
11:         if not callable(record.message):
12:             return record
13: 
14:         try:
15:             record.message = record.message()  # ty:ignore[call-top-callable]
16:         except Exception as exc:  # noqa: BLE001
17:             record.context["lazy_message_error"] = exc
18:             record.message = "<lazy_message_error>"
19:             return record
20:         return record
</file>

