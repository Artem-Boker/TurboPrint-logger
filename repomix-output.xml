 1: from __future__ import annotations
 2: 
 3: from contextlib import contextmanager
 4: from threading import local
 5: from typing import Literal
 6: 
 7: __all__ = ("LocaleManager",)
 8: 
 9: _SUPPORTED_LANGUAGES = Literal["ru_RU", "en_US"]
10: 
11: 
12: class LocaleManager:
13:     _local = local()
14: 
15:     @classmethod
16:     def get(cls) -> _SUPPORTED_LANGUAGES:
17:         return getattr(cls._local, "language", "en_US")
18: 
19:     @classmethod
20:     def set(cls, language: _SUPPORTED_LANGUAGES) -> None:
21:         cls._local.language = language
22: 
23:     @classmethod
24:     @contextmanager
25:     def temporary(cls, language: _SUPPORTED_LANGUAGES):  # noqa: ANN206
26:         original = cls.get()
27:         cls.set(language)
28:         try:
29:             yield
30:         finally:
31:             cls.set(original)
32: 
33:     def __str__(self) -> str:
34:         return f'{self.__class__.__name__}(locale="{self.get()}")'
35: 
36:     def __repr__(self) -> str:
37:         return f'{self.__class__.__name__}(locale="{self.get()}")'
