187:     def disable_auto_reload(self, *, timeout: float = 2.0) -> None:
188:         with self._lock:
189:             thread = self._watch_thread
190:             self._watch_thread = None
191:             self._watch_file = None
192:             self._stop_event.set()
193:         if thread:
194:             thread.join(timeout=timeout)
