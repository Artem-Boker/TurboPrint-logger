 9: 
10: class LevelFilter(Filter):
11:     def __init__(
12:         self,
13:         min_level: Level | None = None,
14:         max_level: Level | None = None,
15:         allowed_levels: list[Level] | None = None,
16:     ) -> None:
17:         self.min_level = min_level
18:         self.max_level = max_level
19:         self.allowed_levels = allowed_levels
20: 
21:     def filter(self, record: Record) -> bool:
22:         level = record.level
23: 
24:         if self.min_level is not None and level.level < self.min_level.level:
25:             return False
26:         if self.max_level is not None and level.level > self.max_level.level:
27:             return False
28: 
29:         return not (self.allowed_levels and level not in self.allowed_levels)
