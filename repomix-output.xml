<file path="src/turboprint_logger/filters/regex.py">
 1: from __future__ import annotations
 2: 
 3: from re import IGNORECASE, Pattern
 4: from re import compile as re_compile
 5: from typing import Literal
 6: 
 7: from turboprint_logger.core.record import Record
 8: from turboprint_logger.interfaces import Filter
 9: 
10: __all__ = ("RegexFilter",)
11: 
12: _FIELDS = Literal["message", "level_name", "logger_name", "file", "function", "line"]
13: 
14: 
15: class RegexFilter(Filter):
16:     def __init__(
17:         self,
18:         pattern: str | Pattern,
19:         field: _FIELDS | str = "message",
20:         *,
21:         ignorecase: bool = True,
22:     ) -> None:
23:         if isinstance(pattern, Pattern):
24:             self.regex = pattern
25:         else:
26:             flags = IGNORECASE if ignorecase else 0
27:             self.regex = re_compile(pattern, flags)
28:         self.field = field
29:         self.ignorecase = ignorecase
30: 
31:     def _get_field_value(self, record: Record) -> str:  # noqa: PLR0911
32:         match self.field.lower():
33:             case "message":
34:                 return (
35:                     record.message() if callable(record.message) else record.message  # ty:ignore[call-top-callable]
36:                 )
37:             case "level_name":
38:                 return record.level.name
39:             case "logger_name":
40:                 return record.logger.name
41:             case "file":
42:                 return record.file
43:             case "function":
44:                 return record.function
45:             case "line":
46:                 return str(record.line)
47:             case _:
48:                 return str(record.context.get(self.field, ""))
49: 
50:     def filter(self, record: Record) -> bool:
51:         text = self._get_field_value(record)
52:         return bool(self.regex.search(text))
</file>

