  1: from __future__ import annotations
  2: 
  3: from collections.abc import Callable
  4: from functools import wraps
  5: from itertools import chain
  6: from time import perf_counter
  7: from typing import Any, TypeVar, cast
  8: 
  9: from turboprint_logger.core.levels import Level, Level
 10: from turboprint_logger.core.logger import Logger
 11: from turboprint_logger.utils.reserved import filter_reserved
 12: 
 13: __all__ = ("event",)
 14: 
 15: _F = TypeVar("_F", bound=Callable[..., Any])
 16: 
 17: 
 18: class EventDecorator:
 19:     def __init__(  # noqa: PLR0913
 20:         self,
 21:         logger: str | Logger | None = None,
 22:         level: Level = Level.EVENT,
 23:         error_level: Level = Level.ERROR,
 24:         arg_parser: Callable[[Any], str] = repr,
 25:         *,
 26:         entry_message: str = "Calling ${function}(${args})",
 27:         exit_message: str = "${function} returned ${result} in ${duration}s",
 28:         exc_message: str = "${function} raised ${exception} in ${duration}s",
 29:         **default_context,
 30:     ) -> None:
 31:         self.logger = (
 32:             logger
 33:             if isinstance(logger, Logger)
 34:             else Logger.get_logger(logger or "root")
 35:         )
 36:         self.level = level
 37:         self.error_level = error_level
 38:         self.arg_parser = arg_parser
 39:         self.entry_message = entry_message
 40:         self.exit_message = exit_message
 41:         self.exc_message = exc_message
 42:         self.default_context = default_context
 43: 
 44:     def __call__(self, func: _F) -> _F:
 45:         @wraps(func)
 46:         def wrapper(*args, **kwargs):  # noqa: ANN202
 47:             arg_parts = chain(
 48:                 (self.arg_parser(arg) for arg in args),
 49:                 (f"{key}={self.arg_parser(value)}" for key, value in kwargs.items()),
 50:             )
 51:             str_args = ", ".join(arg_parts)
 52: 
 53:             entry_extra: dict[str, Any] = {
 54:                 **self.default_context,
 55:                 "event": "entry",
 56:                 "function": func.__name__,
 57:                 "args": str_args,
 58:             }
 59:             self.logger(
 60:                 self.level,
 61:                 self.entry_message,
 62:                 **filter_reserved(entry_extra),
 63:             )
 64:             start_time = perf_counter()
 65: 
 66:             try:
 67:                 result = func(*args, **kwargs)
 68:             except Exception as exc:
 69:                 end_time = perf_counter()
 70:                 exc_extra: dict[str, Any] = {
 71:                     **self.default_context,
 72:                     "event": "exception",
 73:                     "function": func.__name__,
 74:                     "duration": str(round(end_time - start_time, 3)),
 75:                     "exception": repr(exc),
 76:                 }
 77:                 self.logger(
 78:                     self.error_level,
 79:                     self.exc_message,
 80:                     **filter_reserved(exc_extra),
 81:                 )
 82:                 raise
 83: 
 84:             end_time = perf_counter()
 85:             exit_extra: dict[str, Any] = {
 86:                 **self.default_context,
 87:                 "event": "exit",
 88:                 "function": func.__name__,
 89:                 "duration": str(round(end_time - start_time, 3)),
 90:                 "result": repr(result),
 91:             }
 92:             self.logger(
 93:                 self.level,
 94:                 self.exc_message,
 95:                 **filter_reserved(exit_extra),
 96:             )
 97:             return result
 98: 
 99:         return cast(_F, wrapper)
100: 
101: 
102: event = EventDecorator
</file>

