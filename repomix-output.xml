  1: from __future__ import annotations
  2: 
  3: from contextlib import suppress
  4: from gzip import open as gzip_open
  5: from pathlib import Path
  6: from shutil import copyfileobj
  7: from time import time
  8: from typing import Literal
  9: 
 10: from turboprint_logger.core.levels import Level, Level
 11: from turboprint_logger.core.record import Record
 12: from turboprint_logger.handlers.file import FileHandler
 13: from turboprint_logger.interfaces import Filter, Formatter
 14: 
 15: __all__ = ("TimedRotatingFileHandler",)
 16: 
 17: 
 18: class TimedRotatingFileHandler(FileHandler):
 19:     def __init__(  # noqa: PLR0913
 20:         self,
 21:         file_path: str,
 22:         min_level: Level = Level.NOTSET,
 23:         formatter: Formatter | None = None,
 24:         filters: list[Filter] | None = None,
 25:         *,
 26:         separator: str = "\n",
 27:         buffer_size: int | None = None,
 28:         encoding: str = "utf-8",
 29:         update_mode: bool = False,
 30:         compress: bool = True,
 31:         when: Literal["s", "m", "h", "D", "W", "M"] = "h",
 32:         interval: int = 1,
 33:         backup_count: int = 0,
 34:     ) -> None:
 35:         super().__init__(
 36:             file_path=file_path,
 37:             min_level=min_level,
 38:             formatter=formatter,
 39:             filters=filters,
 40:             separator=separator,
 41:             buffer_size=buffer_size,
 42:             encoding=encoding,
 43:             update_mode=update_mode,
 44:         )
 45:         self.compress = compress
 46:         self.when = when.strip()
 47:         self.interval = max(1, interval)
 48:         self.backup_count = backup_count
 49:         self._rotation_seconds = self._get_rotation_seconds()
 50:         self._rollover_at = self._compute_rollover()
 51: 
 52:     def _get_rotation_seconds(self) -> int:
 53:         multipliers = {
 54:             "s": 1,
 55:             "m": 60,
 56:             "h": 60 * 60,
 57:             "D": 60 * 60 * 24,
 58:             "W": 60 * 60 * 24 * 7,
 59:             "M": 60 * 60 * 24 * 30,
 60:         }
 61:         return multipliers.get(self.when, multipliers["h"]) * self.interval
 62: 
 63:     def _compute_rollover(self) -> float:
 64:         return time() + self._rotation_seconds
 65: 
 66:     def _should_rotate(self) -> bool:
 67:         return time() >= self._rollover_at
 68: 
 69:     def _rotated_path(self, number: int) -> Path:
 70:         path = Path(self.file_path)
 71:         suffixes = path.suffixes
 72:         stem = path.name.removesuffix("".join(suffixes)) if suffixes else path.name
 73:         new_name = f"{stem}.{number}{''.join(suffixes)}"
 74:         return path.parent / new_name
 75: 
 76:     @staticmethod
 77:     def _compressed_path(path: Path) -> Path:
 78:         return path.with_suffix(path.suffix + ".gz")
 79: 
 80:     def _rotate(self) -> None:
 81:         with self._lock:
 82:             if self.backup_count <= 0:
 83:                 with suppress(OSError):
 84:                     Path(self.file_path).unlink(missing_ok=True)
 85:                 return
 86: 
 87:             for i in range(self.backup_count - 1, 0, -1):
 88:                 src = self._rotated_path(i)
 89:                 dst = self._rotated_path(i + 1)
 90:                 src_gz = self._compressed_path(src)
 91:                 dst_gz = self._compressed_path(dst)
 92:                 if src_gz.exists():
 93:                     with suppress(OSError):
 94:                         src_gz.replace(dst_gz)
 95:                 elif src.exists():
 96:                     with suppress(OSError):
 97:                         src.replace(dst)
 98: 
 99:             src = Path(self.file_path)
100:             dst = self._rotated_path(1)
101:             if src.exists():
102:                 with suppress(OSError):
103:                     src.replace(dst)
104: 
105:             if self.compress and dst.exists():
106:                 compressed_path = self._compressed_path(dst)
107:                 try:
108:                     with (
109:                         dst.open("rb") as f_in,
110:                         gzip_open(compressed_path, "wb") as f_out,
111:                     ):
112:                         copyfileobj(f_in, f_out)
113:                     dst.unlink(missing_ok=True)
114:                 except Exception:
115:                     with suppress(OSError):
116:                         compressed_path.unlink(missing_ok=True)
117: 
118:     def _write(self, record: Record) -> None:
119:         with self._lock:
120:             if self._should_rotate():
121:                 self.close()
122:                 self._rotate()
123:                 self._open_file()
124:                 self._closed = False
125:                 self._schedule_flush()
126:                 self._rollover_at = self._compute_rollover()
127: 
128:             super()._write(record)
</file>

