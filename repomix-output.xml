<file path="src/turboprint_logger/decorators/deprecated.py">
 1: from __future__ import annotations
 2: 
 3: from collections.abc import Callable
 4: from functools import wraps
 5: from string import Template
 6: from typing import Any, TypeVar, cast
 7: 
 8: from turboprint_logger.core.levels import Level, Level
 9: from turboprint_logger.core.logger import Logger
10: 
11: __all__ = ("deprecated",)
12: 
13: _F = TypeVar("_F", bound=Callable[..., Any])
14: 
15: 
16: class DeprecatedDecorator:
17:     def __init__(
18:         self,
19:         message: str = "The ${function} function has been deprecated and will be removed in a future release.",  # noqa: E501
20:         logger: str | Logger | None = None,
21:         level: Level = Level.EVENT,
22:     ) -> None:
23:         self.logger = (
24:             logger
25:             if isinstance(logger, Logger)
26:             else Logger.get_logger(logger or "root")
27:         )
28:         self.message = Template(message)
29:         self.level = level
30: 
31:     def __call__(self, func: _F) -> _F:
32:         @wraps(func)
33:         def wrapper(*args, **kwargs):  # noqa: ANN202
34:             self.logger(
35:                 self.level, self.message.safe_substitute(function=func.__name__)
36:             )
37:             return func(*args, **kwargs)
38: 
39:         return cast(_F, wrapper)
40: 
41: 
42: deprecated = DeprecatedDecorator
</file>

<file path="src/turboprint_logger/decorators/timed.py">
 1: from __future__ import annotations
 2: 
 3: from collections.abc import Callable
 4: from functools import wraps
 5: from string import Template
 6: from time import perf_counter
 7: from typing import Any, TypeVar, cast
 8: 
 9: from turboprint_logger.core.levels import Level, Level
10: from turboprint_logger.core.logger import Logger
11: 
12: __all__ = ("timed",)
13: 
14: _F = TypeVar("_F", bound=Callable[..., Any])
15: 
16: 
17: class TimedDecorator:
18:     def __init__(
19:         self,
20:         logger: str | Logger | None = None,
21:         level: Level = Level.EVENT,
22:         message: str = "${function} completed in ${duration}",
23:         duration_round: int = 3,
24:     ) -> None:
25:         self.logger = (
26:             logger
27:             if isinstance(logger, Logger)
28:             else Logger.get_logger(logger or "root")
29:         )
30:         self.level = level
31:         self.message = Template(message)
32:         self.duration_round = duration_round
33: 
34:     def __call__(self, func: _F) -> _F:
35:         @wraps(func)
36:         def wrapper(*args, **kwargs):  # noqa: ANN202
37:             start = perf_counter()
38:             try:
39:                 return func(*args, **kwargs)
40:             finally:
41:                 duration = perf_counter() - start
42:                 self.logger(
43:                     self.level,
44:                     self.message.safe_substitute(
45:                         function=func.__name__,
46:                         duration=round(duration, self.duration_round),
47:                     ),
48:                 )
49: 
50:         return cast(_F, wrapper)
51: 
52: 
53: timed = TimedDecorator
</file>

