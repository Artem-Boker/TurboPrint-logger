  9: from turboprint_logger.core.levels import Level, Level
 10: from turboprint_logger.core.record import Record
 11: from turboprint_logger.exceptions.handlers.stream import (
 12:     InvalidBufferSizeError,
 13:     InvalidStreamError,
 14:     InvalidStreamFlushIntervalError,
 15: )
 16: from turboprint_logger.interfaces import Filter, Formatter, Handler
 17: 
 18: __all__ = ("BufferedStreamHandler",)
 19: 
 20: 
 21: class BufferedStreamHandler(Handler):
 22:     def __init__(  # noqa: PLR0913
 23:         self,
 24:         stream: TextIO = default_output,
 25:         buffer_size: int = 1_000,
 26:         flush_interval: int = 60,
 27:         min_level: Level = Level.NOTSET,
 28:         formatter: Formatter | None = None,
 29:         filters: list[Filter] | None = None,
 30:     ) -> None:
 31:         super().__init__(min_level, formatter, filters)
 32:         if not callable(getattr(stream, "write", None)):
 33:             msg = "stream must provide a callable 'write' method"
 34:             raise InvalidStreamError(msg)
 35:         if not callable(getattr(stream, "flush", None)):
 36:             msg = "stream must provide a callable 'flush' method"
 37:             raise InvalidStreamError(msg)
 38:         if not isinstance(buffer_size, int):
 39:             msg = "buffer_size must be an integer"
 40:             raise InvalidBufferSizeError(msg)
 41:         if buffer_size < 1:
 42:             msg = "buffer_size must be greater than 0"
 43:             raise InvalidBufferSizeError(msg)
 44:         if not isinstance(flush_interval, int | float):
 45:             msg = "flush_interval must be a number"
 46:             raise InvalidStreamFlushIntervalError(msg)
 47:         if flush_interval <= 0:
 48:             msg = "flush_interval must be greater than 0"
 49:             raise InvalidStreamFlushIntervalError(msg)
 50:         self.stream = stream
 51:         self.buffer: list[str] = []
 52:         self.buffer_size = buffer_size
 53:         self.flush_interval = flush_interval
 54:         self._timer: Timer | None = None
 55:         self._closed = False
 56:         self._lock = RLock()
 57:         _self_ref = ref(self)
 58: 
 59:         def _atexit_close() -> None:
 60:             obj = _self_ref()
 61:             if obj is not None:
 62:                 obj.close()
 63: 
 64:         register_exit(_atexit_close)
 65:         self._schedule_flush()
 66: 
 67:     def _schedule_flush(self) -> None:
 68:         with self._lock:
 69:             if self._closed:
 70:                 return
 71:             timer = Timer(interval=self.flush_interval, function=self._on_timer_flush)
 72:             timer.daemon = True
 73:             self._timer = timer
 74:             timer.start()
 75: 
 76:     def _on_timer_flush(self) -> None:
 77:         try:
 78:             self.flush()
 79:         finally:
 80:             with self._lock:
 81:                 if not self._closed:
 82:                     self._schedule_flush()
 83: 
 84:     def emit(self, record: Record) -> None:
 85:         with self._lock:
 86:             formatter = self.formatter or record.logger.formatter.get()
 87:             self.buffer.append(formatter.format(record))
 88:             if len(self.buffer) >= self.buffer_size:
 89:                 self.flush()
 90: 
 91:     def flush(self) -> None:
 92:         with self._lock:
 93:             if self.buffer:
 94:                 self.stream.write("\n".join(self.buffer) + "\n")
 95:                 self.stream.flush()
 96:                 self.buffer.clear()
 97: 
 98:     def close(self) -> None:
 99:         with self._lock:
100:             self._closed = True
101:             if self._timer is not None:
102:                 self._timer.cancel()
103:                 self._timer = None
104:             self.flush()
