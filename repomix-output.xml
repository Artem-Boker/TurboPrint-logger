 20: 
 21: __all__ = ("Level", "Level")
 22: 
 23: 
 24: @dataclass(frozen=True, slots=True)
 25: class Level:
 26:     name: str
 27:     level: int
 28:     color: str
 29:     emoji: str | None = None
 30: 
 31:     def __str__(self) -> str:
 32:         return f"{self.__class__.__name__}({self.name}[{self.level}])"
 33: 
 34:     def __repr__(self) -> str:
 35:         return (
 36:             f"{self.__class__.__name__}("
 37:             f'name="{self.name}", '
 38:             f"level={self.level}, "
 39:             f"emoji={self.emoji})"
 40:         )
 41: 
 42:     def enabled_for(self, level: Level) -> bool:
 43:         return self.level >= level.level
 44: 
 45: 
 46: def _register_levels(cls: type[Level]) -> type[Level]:
 47:     for level in vars(cls).values():
 48:         if isinstance(level, Level):
 49:             cls._by_name[level.name] = level
 50:             cls._by_level[level.level] = level
 51:     return cls
 52: 
 53: 
 54: @_register_levels
 55: class Level:
 56:     _lock = Lock()
 57: 
 58:     NOTSET = Level("NOTSET", 0, Fore.RESET)
 59:     VERBOSE = Level("VERBOSE", 10, Fore.LIGHTBLACK_EX)
 60:     DEBUG = Level("DEBUG", 20, Fore.MAGENTA)
 61:     TRACE = Level("TRACE", 30, Fore.BLUE)
 62:     LOG = Level("LOG", 40, Fore.CYAN)
 63:     NOTICE = Level("NOTICE", 50, Fore.LIGHTYELLOW_EX)
 64:     EVENT = Level("EVENT", 60, Fore.LIGHTCYAN_EX)
 65:     PERFORMANCE = Level("PERFORMANCE", 70, Fore.CYAN)
 66:     SUCCESS = Level("SUCCESS", 80, Fore.GREEN)
 67:     SECURITY = Level("SECURITY", 90, Fore.LIGHTGREEN_EX)
 68:     AUDIT = Level("AUDIT", 100, Fore.YELLOW)
 69:     INFO = Level("INFO", 110, Fore.LIGHTBLUE_EX)
 70:     WARNING = Level("WARNING", 120, Fore.RED)
 71:     ERROR = Level("ERROR", 130, Fore.LIGHTRED_EX)
 72:     ALERT = Level("ALERT", 140, Style.BRIGHT + Fore.YELLOW)
 73:     CRITICAL = Level("CRITICAL", 150, Style.BRIGHT + Fore.LIGHTRED_EX)
 74:     FATAL = Level("FATAL", 160, Style.BRIGHT + Fore.MAGENTA)
 75:     EMERGENCY = Level("EMERGENCY", 170, Style.BRIGHT + Fore.RED)
 76: 
 77:     _by_name: ClassVar[dict[str, Level]] = {}
 78:     _by_level: ClassVar[dict[int, Level]] = {}
 79: 
 80:     @classmethod
 81:     @cache
 82:     def get_by_name(cls, name: str) -> Level | None:
 83:         with cls._lock:
 84:             return cls._by_name.get(name.strip().upper())
 85: 
 86:     @classmethod
 87:     @cache
 88:     def get_by_level(cls, level: int) -> Level | None:
 89:         with cls._lock:
 90:             return cls._by_level.get(level)
 91: 
 92:     @classmethod
 93:     @cache
 94:     def all_levels(cls) -> list[Level]:
 95:         with cls._lock:
 96:             return sorted(cls._by_level.values(), key=lambda lvl: lvl.level)
 97: 
 98:     @classmethod
 99:     def register(  # noqa: C901
100:         cls,
101:         name: str,
102:         level: int,
103:         color: str = Fore.RESET,
104:         emoji_name: str | None = None,
105:     ) -> Level:
106:         name_upper = normalize_level_name(name)
107:         with cls._lock:
108:             if name_upper in Level._by_name:
109:                 msg = f'Level with name "{name_upper}" already exists'
110:                 raise LevelNameAlreadyExistsError(msg)
111:             if level in Level._by_level:
112:                 msg = f"Level with value {level} already exists"
113:                 raise LevelValueAlreadyExistsError(msg)
114:             if level < 0:
115:                 msg = f'Level "{name_upper}" cannot be negative: {level}'
116:                 raise NegativeLevelError(msg)
117:             if not isinstance(color, str) or not color:
118:                 msg = f"Invalid color: {color!r}"
119:                 raise InvalidLevelColorError(msg)
120:             emoji = emoji_name.strip().lower() if emoji_name else emoji_name
121:             if emoji and not is_emoji(emoji):
122:                 if not emoji.startswith(":"):
123:                     emoji = ":" + emoji
124:                 if not emoji.endswith(":"):
125:                     emoji = emoji + ":"
126:                 for lang in EMOJI_LANGUAGES:
127:                     emoji = emojize(emoji, variant="emoji_type", language=lang)
128:                     if is_emoji(emoji):
129:                         break
130:                 if not is_emoji(emoji):
131:                     msg = f"Invalid emoji code: {emoji_name}"
132:                     raise InvalidLevelEmojiError(msg)
133: 
134:         with cls._lock:
135:             cls.get_by_name.cache_clear()
136:             cls.get_by_level.cache_clear()
137:             cls.all_levels.cache_clear()
138:             new_level = Level(name_upper, level, color, emoji)
139:             cls._by_name[name_upper] = new_level
140:             cls._by_level[level] = new_level
141:         return new_level
142: 
143:     def __str__(self) -> str:
144:         return f"{self.__class__.__name__}(levels_count={len(self._by_level)})"
145: 
146:     def __repr__(self) -> str:
147:         return f"{self.__class__.__name__}(levels_count={len(self._by_level)})"
