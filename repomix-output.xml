 35:     s.run("ruff", "check")
 36:     s.run("ty", "check")
 37: 
 38: 
 39: @session(uv_groups=["formats"])
 40: def formats(s: Session) -> None:
 41:     """Запуск форматеров кода (fix)."""
 42:     s.run("ruff", "check", "--fix")
 43:     s.run("ruff", "format")
 44: 
 45: 
 46: @session(uv_groups=["formats"])
 47: def check_format(s: Session) -> None:
 48:     """Проверка форматирования без исправления."""
 49:     s.run("ruff", "check")
 50:     s.run("ruff", "format", "--check")
 51: 
 52: 
 53: @session(uv_groups=["docs"])
 54: def docs(s: Session) -> None:
 55:     """Запуск генерации документации"""
 56:     docs_source = Path("docs")
 57:     if not docs_source.exists():
 58:         s.error("docs source directory does not exist")
 59:     docs_build = docs_source / "_build"
 60:     if docs_build.exists():
 61:         rmtree(docs_build)
 62:     s.run("sphinx-build", "-b", "html", "docs", "docs/_build/html")
 63: 
 64: 
 65: @session(uv_groups=["security"])
 66: def security(s: Session) -> None:
 67:     """Комплексная проверка безопасности"""
 68:     baseline = Path(".secrets.baseline")
 69:     if baseline.exists():
 70:         s.run("detect-secrets", "scan", "--baseline", str(baseline), "src")
 71:     else:
 72:         s.run("detect-secrets", "scan", "src")
 73: 
 74:     s.run("bandit", "-r", "src")
 75:     s.run("pip-audit")
 76: 
 77: 
 78: @session(uv_groups=["builds"])
 79: def builds(s: Session) -> None:
 80:     """Запуск сборки проекта"""
 81:     for folder in ("build", "dist"):
 82:         if Path(folder).exists():
 83:             rmtree(folder)
 84:     s.run("build", "--outdir", "dist")
 85: 
 86: 
 87: def _get_size(path: Path) -> int:
 88:     if path.is_file():
 89:         return path.stat().st_size
 90:     if path.is_dir():
 91:         size = 0
 92:         for file in path.rglob("*"):
 93:             if file.is_file():
 94:                 size += file.stat().st_size
 95:         return size
 96:     return 0
 97: 
 98: 
 99: @session()
100: def clean(s: Session) -> None:
101:     """Очистка временных и служебных файлов."""
102:     total_size = 0
103: 
104:     for folder in [*BUILD_DIRS, *CACHE_DIRS]:
105:         path = Path(folder)
106:         if path.exists():
107:             total_size += _get_size(path)
108:             rmtree(path)
109: 
110:     for file in REPORT_FILES:
111:         file_path = Path(file)
112:         if file_path.exists():
113:             total_size += _get_size(file_path)
114:             file_path.unlink(missing_ok=True)
115: 
116:     for pycache in Path().rglob("__pycache__"):
117:         if pycache.exists():
118:             total_size += _get_size(pycache)
119:             rmtree(pycache)
120: 
121:     for pyc in Path().rglob("*.pyc"):
122:         if pyc.exists():
123:             total_size += _get_size(pyc)
124:             pyc.unlink(missing_ok=True)
125: 
126:     kb_size = total_size / 1024
127:     mb_size = total_size / 1024 / 1024
128:     gb_size = total_size / 1024 / 1024 / 1024
129: 
130:     s.log(
131:         f"Total size: "
132:         f"{total_size} B // "
133:         f"{kb_size:.2f} KB // "
134:         f"{mb_size:.2f} MB // "
135:         f"{gb_size:.2f} GB"
136:     )
</file>

