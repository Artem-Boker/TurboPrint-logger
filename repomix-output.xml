21:             return tuple(self._processors)
22: 
23:     def add(self, *processors: Processor) -> None:
24:         with self._lock:
25:             self._processors.extend(processors)
26: 
27:     def remove(self, processor: Processor) -> bool:
28:         try:
29:             with self._lock:
30:                 self._processors.remove(processor)
31:         except ValueError:
32:             return False
33:         return True
34: 
35:     def clear(self) -> None:
36:         with self._lock:
37:             self._processors.clear()
38: 
39:     @contextmanager
40:     def temporary(self, *processors: Processor, replace: bool = True):  # noqa: ANN201
41:         with self._lock:
42:             original = self._processors
43:             self._processors = (
44:                 list(processors) if replace else [*self._processors, *processors]
45:             )
46:         try:
47:             yield
48:         finally:
49:             with self._lock:
50:                 self._processors = original
51: 
52:     def __len__(self) -> int:
53:         with self._lock:
54:             return len(self._processors)
55: 
56:     def __iter__(self) -> Iterator[Processor]:
57:         with self._lock:
58:             return iter(self._processors.copy())
59: 
60:     def __getitem__(self, index: int) -> Processor:
61:         with self._lock:
62:             return self._processors[index]
63: 
64:     def __contains__(self, processor: Processor) -> bool:
65:         with self._lock:
66:             return processor in self._processors
67: 
68:     def __str__(self) -> str:
69:         return f"{self.__class__.__name__}(processors_count={len(self._processors)})"
70: 
71:     def __repr__(self) -> str:
72:         return f"{self.__class__.__name__}(processors={self._processors})"
</file>

