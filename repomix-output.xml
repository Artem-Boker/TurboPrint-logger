 22: 
 23: class FileHandler(Handler):
 24:     def __init__(  # noqa: PLR0913
 25:         self,
 26:         file_path: str,
 27:         min_level: Level = Level.NOTSET,
 28:         formatter: Formatter | None = None,
 29:         filters: list[Filter] | None = None,
 30:         *,
 31:         separator: str = "\n",
 32:         buffer_size: int | None = None,
 33:         flush_interval: int = 60,
 34:         encoding: str = "utf-8",
 35:         update_mode: bool = False,
 36:     ) -> None:
 37:         super().__init__(min_level, formatter, filters)
 38:         if not isinstance(separator, str):
 39:             msg = "separator must be a string"
 40:             raise InvalidSeparatorError(msg)
 41:         if not isinstance(flush_interval, int | float):
 42:             msg = "flush_interval must be a number"
 43:             raise InvalidFlushIntervalError(msg)
 44:         if flush_interval <= 0:
 45:             msg = "flush_interval must be greater than 0"
 46:             raise InvalidFlushIntervalError(msg)
 47:         if not separator:
 48:             msg = "separator must be a non-empty string"
 49:             raise InvalidSeparatorError(msg)
 50:         self.file_path = Path(file_path)
 51:         self.mode = "a" if update_mode else "w"
 52:         self.encoding = encoding
 53:         self.buffer_size = 1 if not buffer_size or buffer_size < 1 else buffer_size
 54:         self.separator = separator
 55:         self.flush_interval = flush_interval
 56:         self._timer: Timer | None = None
 57:         self._closed = False
 58:         self._file: IO | None = None
 59:         self._lock = RLock()
 60:         self._open_file()
 61:         register_exit(self.close)
 62:         self._schedule_flush()
 63: 
 64:     def _schedule_flush(self) -> None:
 65:         with self._lock:
 66:             if self._closed:
 67:                 return
 68:             timer = Timer(interval=self.flush_interval, function=self._flush)
 69:             timer.daemon = True
 70:             self._timer = timer
 71:             timer.start()
 72: 
 73:     def _flush(self) -> None:
 74:         try:
 75:             with self._lock:
 76:                 if self._closed:
 77:                     return
 78:                 if self._file and not self._file.closed:
 79:                     self._file.flush()
 80:         finally:
 81:             self._schedule_flush()
 82: 
 83:     def _open_file(self) -> None:
 84:         with self._lock:
 85:             try:
 86:                 self.file_path.parent.mkdir(parents=True, exist_ok=True)
 87:                 self.file_path.touch(exist_ok=True)
 88:                 self._file = self.file_path.open(
 89:                     self.mode, encoding=self.encoding, buffering=self.buffer_size
 90:                 )
 91:             except Exception as exc:
 92:                 msg = f"Could not open file {self.file_path}: {exc}"
 93:                 raise FileOpenError(msg) from exc
 94: 
 95:     def reopen(self) -> None:
 96:         with self._lock:
 97:             if self._file and not self._file.closed:
 98:                 self._file.close()
 99:             self._file = None
100:             self._closed = False
101:             original_mode = self.mode
102:             self.mode = "a"
103:             try:
104:                 self._open_file()
105:             finally:
106:                 self.mode = original_mode
107:             if self._timer is None:
108:                 self._schedule_flush()
109: 
110:     def close(self) -> None:
111:         with self._lock:
112:             self._closed = True
113:             if self._timer is not None:
114:                 self._timer.cancel()
115:                 self._timer = None
116:             if self._file and not self._file.closed:
117:                 self._file.close()
118:             self._file = None
119: 
120:     def _write(self, record: Record) -> None:
121:         with self._lock:
122:             if not self._file:
123:                 self._open_file()
124:             formatter = self.formatter or record.logger.formatter.get()
125:             if self._file and not self._file.closed:
126:                 try:
127:                     self._file.write(formatter.format(record) + self.separator)
128:                 except Exception as exc:
129:                     msg = f"Could not write to file {self.file_path}: {exc}"
130:                     raise FileWriteError(msg) from exc
131:             else:
132:                 msg = f"File {self.file_path} is closed"
133:                 raise FileClosedError(msg)
134: 
135:     def emit(self, record: Record) -> None:
136:         try:
137:             self._write(record)
138:         except Exception as exc:  # noqa: BLE001
139:             stderr.write(
140:                 f"{exc.__class__.__name__}[{self.__class__.__name__}]: {exc}\n"
141:             )
142:             self.reopen()
143:             try:
144:                 self._write(record)
145:             except Exception as exc:  # noqa: BLE001
146:                 stderr.write(
147:                     f"{exc.__class__.__name__}[{self.__class__.__name__}]: Failed to write to {self.file_path}: {exc}\n"  # noqa: E501
