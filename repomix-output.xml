 1: from __future__ import annotations
 2: 
 3: from collections.abc import Callable
 4: from threading import RLock
 5: from typing import TypeVar
 6: 
 7: from turboprint_logger.exceptions.core.plugins import (
 8:     PluginAlreadyRegisteredError,
 9:     PluginNotFoundError,
10:     PluginTypeError,
11: )
12: from turboprint_logger.interfaces import Filter, Formatter, Handler, Processor
13: 
14: __all__ = (
15:     "get_filter",
16:     "get_formatter",
17:     "get_handler",
18:     "get_processor",
19:     "register_filter",
20:     "register_formatter",
21:     "register_handler",
22:     "register_processor",
23: )
24: 
25: _T = TypeVar("_T", bound=type[Handler | Filter | Formatter | Processor])
26: _HANDLER = TypeVar("_HANDLER", bound=type[Handler])
27: _FILTER = TypeVar("_FILTER", bound=type[Filter])
28: _FORMATTER = TypeVar("_FORMATTER", bound=type[Formatter])
29: _PROCESSOR = TypeVar("_PROCESSOR", bound=type[Processor])
30: 
31: _handlers_lock = RLock()
32: _filters_lock = RLock()
33: _formatters_lock = RLock()
34: _processors_lock = RLock()
35: 
36: _handlers: dict[str, type[Handler]] = {}
37: _filters: dict[str, type[Filter]] = {}
38: _formatters: dict[str, type[Formatter]] = {}
39: _processors: dict[str, type[Processor]] = {}
40: 
41: 
42: def _register(
43:     type_: _T, lock: RLock, dict_: dict[str, _T], name: str | None = None
44: ) -> Callable[[_T], _T]:
45:     def decorator(cls: _T) -> _T:
46:         if not issubclass(cls, type_):
47:             msg = f"{cls.__name__} must be subclass of {type_.__name__}"
48:             raise PluginTypeError(msg)
49:         with lock:
50:             key = name or cls.__name__
51:             if key in dict_ and dict_[key] is not cls:
52:                 msg = f"{cls.__name__} {key!r} already registered"
53:                 raise PluginAlreadyRegisteredError(msg)
54:             dict_[key] = cls
55:         return cls
56: 
57:     return decorator
58: 
59: 
60: def _get(dict_: dict[str, _T], type_: _T, name: str) -> _T:
61:     try:
62:         return dict_[name]
63:     except KeyError:
64:         msg = f"Unknown {type_.__name__.lower()}: {name}"
65:         raise PluginNotFoundError(msg) from None
66: 
67: 
68: def register_handler(name: str | None = None) -> Callable[[_HANDLER], _HANDLER]:
69:     return _register(Handler, _handlers_lock, _handlers, name)  # pyright: ignore[reportReturnType]
70: 
71: 
72: def get_handler(name: str) -> type[Handler]:
73:     return _get(_handlers, Handler, name)
74: 
75: 
76: def register_filter(name: str | None = None) -> Callable[[_FILTER], _FILTER]:
77:     return _register(Filter, _filters_lock, _filters, name)  # pyright: ignore[reportReturnType]
78: 
79: 
80: def get_filter(name: str) -> type[Filter]:
81:     return _get(_filters, Filter, name)
82: 
83: 
84: def register_formatter(name: str | None = None) -> Callable[[_FORMATTER], _FORMATTER]:
85:     return _register(Formatter, _formatters_lock, _formatters, name)  # pyright: ignore[reportReturnType]
86: 
87: 
88: def get_formatter(name: str) -> type[Formatter]:
89:     return _get(_formatters, Formatter, name)
90: 
91: 
92: def register_processor(name: str | None = None) -> Callable[[_PROCESSOR], _PROCESSOR]:
93:     return _register(Processor, _processors_lock, _processors, name)  # pyright: ignore[reportReturnType]
