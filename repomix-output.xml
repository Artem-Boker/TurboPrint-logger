 1: from __future__ import annotations
 2: 
 3: from collections.abc import Callable
 4: from functools import wraps
 5: from string import Template
 6: from time import sleep
 7: from typing import Any, TypeVar, cast
 8: 
 9: from turboprint_logger.core.levels import Level, Level
10: from turboprint_logger.core.logger import Logger
11: from turboprint_logger.exceptions.decorators.retry import (
12:     RetryLimitExceededError,
13:     UnknownRetryError,
14: )
15: 
16: __all__ = ("retry",)
17: 
18: _F = TypeVar("_F", bound=Callable[..., Any])
19: 
20: 
21: class RetryDecorator:
22:     def __init__(  # noqa: PLR0913
23:         self,
24:         max_attempts: int = 3,
25:         delay: float = 1.0,
26:         backoff: float = 2.0,
27:         exceptions: tuple[type[Exception], ...] = (Exception,),
28:         logger: str | Logger | None = None,
29:         success_level: Level = Level.SUCCESS,
30:         success_message: str = "${function} succeeded after ${attempt} attempt",
31:         warning_level: Level = Level.WARNING,
32:         warning_message: str = "Attempt ${attempt} for ${function} failed: ${exception}",  # noqa: E501
33:         error_level: Level = Level.ERROR,
34:         error_message: str = "Function ${function} failed after ${attempt} attempt",
35:     ) -> None:
36:         self.logger = (
37:             logger
38:             if isinstance(logger, Logger)
39:             else Logger.get_logger(logger or "root")
40:         )
41:         self.max_attempts = max(1, max_attempts)
42:         self.delay = delay
43:         self.backoff = backoff
44:         self.exceptions = exceptions
45:         self.success_level = success_level
46:         self.success_message = Template(success_message)
47:         self.warning_level = warning_level
48:         self.warning_message = Template(warning_message)
49:         self.error_level = error_level
50:         self.error_message = Template(error_message)
51: 
52:     def __call__(self, func: _F) -> _F:
53:         @wraps(func)
54:         def wrapper(*args, **kwargs):  # noqa: ANN202
55:             last_exc = None
56:             for attempt in range(1, self.max_attempts + 1):
57:                 try:
58:                     result = func(*args, **kwargs)
59:                     if attempt > 1:
60:                         self.logger(
61:                             self.success_level,
62:                             self.success_message.safe_substitute(
63:                                 function=func.__name__, attempt=attempt
64:                             ),
65:                         )
66:                 except self.exceptions as exc:
67:                     last_exc = exc
68:                     self.logger(
69:                         self.warning_level,
70:                         self.warning_message.safe_substitute(
71:                             function=func.__name__, attempt=attempt, exception=exc
72:                         ),
73:                     )
74:                     if attempt < self.max_attempts:
75:                         sleep(self.delay * (self.backoff ** (attempt - 1)))
76:                 else:
77:                     return result
78:             self.logger(
79:                 self.error_level,
80:                 self.error_message.safe_substitute(
81:                     function=func.__name__, attempt=attempt
82:                 ),
83:             )
84:             if last_exc:
85:                 msg = f"{func.__name__}, last exception: {last_exc}"
86:                 raise RetryLimitExceededError(msg) from last_exc
87:             msg = "Unknown error in retry"
88:             raise UnknownRetryError(msg)
89: 
90:         return cast(_F, wrapper)
91: 
92: 
93: retry = RetryDecorator
</file>

