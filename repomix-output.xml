152:     def enable_auto_reload(
153:         self,
154:         file_path: str | Path,
155:         *,
156:         interval: float = 1.0,
157:         load_initial: bool = True,
158:     ) -> None:
159:         path = Path(file_path)
160:         if interval <= 0:
161:             msg = "Auto-reload interval must be > 0"
162:             raise ConfigReloadError(msg)
163: 
164:         with self._lock:
165:             if self._watch_thread and self._watch_thread.is_alive():
166:                 msg = "Auto-reload already enabled"
167:                 raise ConfigWatchAlreadyRunningError(msg)
168:             self._watch_file = path
169:             self._watch_interval = interval
170:             self._stop_event.clear()
171:             self._watch_thread = Thread(target=self._watch_loop, daemon=True)
172:             thread = self._watch_thread
173: 
174:         if load_initial:
175:             try:
176:                 self.load_file(path)
177:             except Exception:
178:                 with self._lock:
179:                     self._watch_file = None
180:                     self._watch_thread = None
181:                     self._stop_event.set()
182:                 raise
183: 
184:         if thread:
185:             thread.start()
