 21: class RotatingFileHandler(FileHandler):
 22:     def __init__(  # noqa: PLR0913
 23:         self,
 24:         file_path: str,
 25:         min_level: Level = Level.NOTSET,
 26:         formatter: Formatter | None = None,
 27:         filters: list[Filter] | None = None,
 28:         *,
 29:         separator: str = "\n",
 30:         buffer_size: int | None = None,
 31:         encoding: str = "utf-8",
 32:         update_mode: bool = False,
 33:         compress: bool = True,
 34:         max_bytes: int | None = None,
 35:         max_lines: int | None = None,
 36:         backup_count: int = 0,
 37:     ) -> None:
 38:         super().__init__(
 39:             file_path=file_path,
 40:             min_level=min_level,
 41:             formatter=formatter,
 42:             filters=filters,
 43:             separator=separator,
 44:             buffer_size=buffer_size,
 45:             encoding=encoding,
 46:             update_mode=update_mode,
 47:         )
 48:         if max_bytes is None and max_lines is None:
 49:             msg = f"{self.__class__.__name__} required at least one of max_bytes or max_lines"
 50:             raise FileHandlerConfigError(msg)
 51:         self.compress = compress
 52:         self.max_bytes = max_bytes
 53:         self.max_lines = max_lines
 54:         self.backup_count = backup_count
 55:         self._line_count = 0
 56:         self._current_size = 0
 57:         self._update_counts()
 58: 
 59:     def _update_counts(self) -> None:
 60:         path = Path(self.file_path)
 61:         size = 0
 62:         line_count = 0
 63:         if path.exists():
 64:             size = path.stat().st_size
 65:             if self.max_lines is not None:
 66:                 try:
 67:                     with path.open("r", encoding=self.encoding) as file:
 68:                         line_count = sum(1 for _ in file)
 69:                 except OSError:
 70:                     line_count = 0
 71:         with self._lock:
 72:             self._current_size = size
 73:             self._line_count = line_count
 74: 
 75:     def _should_rotate(self, record: Record) -> bool:  # noqa: ARG002
 76:         if self.max_bytes is not None and self._current_size >= self.max_bytes:
 77:             return True
 78:         return bool(self.max_lines is not None and self._line_count >= self.max_lines)
 79: 
 80:     def _rotated_path(self, number: int) -> Path:
 81:         path = Path(self.file_path)
 82:         suffixes = path.suffixes
 83:         stem = path.name.removesuffix("".join(suffixes)) if suffixes else path.name
 84:         new_name = f"{stem}.{number}{''.join(suffixes)}"
 85:         return path.parent / new_name
 86: 
 87:     @staticmethod
 88:     def _compressed_path(path: Path) -> Path:
 89:         return path.with_suffix(path.suffix + ".gz")
 90: 
 91:     def _rotate(self) -> None:
 92:         with self._lock:
 93:             if self.backup_count <= 0:
 94:                 with suppress(OSError):
 95:                     Path(self.file_path).unlink(missing_ok=True)
 96:                 return
 97: 
 98:             for i in range(self.backup_count - 1, 0, -1):
 99:                 src = self._rotated_path(i)
100:                 dst = self._rotated_path(i + 1)
101:                 src_gz = self._compressed_path(src)
102:                 dst_gz = self._compressed_path(dst)
103:                 if src_gz.exists():
104:                     with suppress(OSError):
105:                         src_gz.replace(dst_gz)
106:                 elif src.exists():
107:                     with suppress(OSError):
108:                         src.replace(dst)
109: 
110:             src = Path(self.file_path)
111:             dst = self._rotated_path(1)
112:             if src.exists():
113:                 with suppress(OSError):
114:                     src.replace(dst)
115: 
116:             if self.compress and dst.exists():
117:                 compressed_path = self._compressed_path(dst)
118:                 try:
119:                     with (
120:                         dst.open("rb") as f_in,
121:                         gzip_open(compressed_path, "wb") as f_out,
122:                     ):
123:                         copyfileobj(f_in, f_out)
124:                     dst.unlink(missing_ok=True)
125:                 except Exception:
126:                     with suppress(OSError):
127:                         compressed_path.unlink(missing_ok=True)
128: 
129:     def _write(self, record: Record) -> None:
130:         with self._lock:
131:             if self._should_rotate(record):
132:                 self.close()
133:                 self._rotate()
134:                 self._open_file()
135:                 self._closed = False
136:                 self._schedule_flush()
137:                 self._update_counts()
138: 
139:             formatter = self.formatter or record.logger.formatter.get()
140:             line = formatter.format(record) + self.separator
141:             if self._file and not self._file.closed:
142:                 try:
143:                     self._file.write(line)
144:                 except Exception as exc:
145:                     msg = f"Could not write to file {self.file_path}: {exc}"
146:                     raise FileWriteError(msg) from exc
147:             else:
148:                 msg = f"File {self.file_path} is closed"
149:                 raise FileClosedError
150:             self._current_size += len(line.encode(self.encoding))
151:             if self.max_lines is not None:
152:                 self._line_count += 1
153: 
154:     def reopen(self) -> None:
155:         super().reopen()
156:         self._update_counts()
