10: class TagsManager:
11:     __slots__ = ("_lock", "_tags")
12: 
13:     def __init__(self, *tags: str) -> None:
14:         self._lock = Lock()
15:         self._tags: set[str] = set(tags)
16: 
17:     def get(self) -> set[str]:
18:         with self._lock:
19:             return self._tags.copy()
20: 
21:     def add(self, *tags: str) -> None:
22:         with self._lock:
23:             self._tags.update(tags)
24: 
25:     def remove(self, tag: str) -> None:
26:         with self._lock:
27:             return self._tags.discard(tag)
28: 
29:     def clear(self) -> None:
30:         with self._lock:
31:             self._tags.clear()
32: 
33:     @contextmanager
34:     def temporary(self, *tags: str, replace: bool = True):  # noqa: ANN201
35:         with self._lock:
36:             original = self._tags
37:             self._tags = set(tags) if replace else {*self._tags, *tags}
38:         try:
39:             yield
40:         finally:
41:             with self._lock:
42:                 self._tags = original
43: 
44:     def __len__(self) -> int:
45:         with self._lock:
46:             return len(self._tags)
47: 
48:     def __iter__(self) -> Iterator[str]:
49:         with self._lock:
50:             return iter(self._tags.copy())
51: 
52:     def __getitem__(self, index: int) -> str:
53:         with self._lock:
54:             return list(self._tags)[index]
55: 
56:     def __contains__(self, tag: str) -> bool:
57:         with self._lock:
58:             return tag in self._tags
59: 
60:     def __str__(self) -> str:
61:         return f"{self.__class__.__name__}(tags_count={len(self)})"
62: 
63:     def __repr__(self) -> str:
