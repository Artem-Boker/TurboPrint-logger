{
  "loggers": {
    "root": {
      "min_level": "INFO",
      "formatter": {
        "name": "SimpleFormatter",
        "kwargs": {
          "template": "${level_name}: ${message}"
        }
      },
      "handlers": [
        {
          "name": "StreamHandler",
          "kwargs": {}
        }
      ],
      "filters": []
    },
    "app.api": {
      "min_level": "DEBUG",
      "propagate": true,
      "status": true,
      "context": {
        "service": "api"
      },
      "tags": ["backend"]
    }
  }
}
