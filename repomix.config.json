{
    "$schema": "https://repomix.com/schemas/latest/schema.json",
    "input": {
        "maxFileSize": 50000000
    },
    "output": {
        "filePath": "repomix-output.xml",
        "style": "xml",
        "parsableStyle": false,
        "compress": false,
        "headerText": "Python codebase for security and logic audit.",
        "instructionFilePath": "",
        "fileSummary": true,
        "directoryStructure": true,
        "files": true,
        "removeComments": false,
        "removeEmptyLines": false,
        "showLineNumbers": true,
        "topFilesLength": 0,
        "includeEmptyDirectories": false,
        "truncateBase64": true,
        "tokenCountTree": 0
    },
    "include": [],
    "ignore": {
        "useGitignore": true,
        "useDefaultPatterns": true,
        "customPatterns": []
    },
    "security": {
        "enableSecurityCheck": true
    },
    "tokenCount": {
        "encoding": "o200k_base"
    }
}
